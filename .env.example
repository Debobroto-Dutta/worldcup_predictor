# Environment Configuration Example
# Copy this file to .env and update with your values

# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production
FLASK_ENV=development

# Database Configuration
DATABASE_URL=sqlite:///worldcup.db

# For production, use PostgreSQL:
# DATABASE_URL=postgresql://username:password@localhost/worldcup_db

# Server Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Email Configuration (Required for password reset)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@worldcuppredictor.com

# For Gmail:
# 1. Enable 2-factor authentication
# 2. Generate an "App Password" at https://myaccount.google.com/apppasswords
# 3. Use the app password as MAIL_PASSWORD

# For other email providers:
# - Outlook: smtp.office365.com, port 587
# - Yahoo: smtp.mail.yahoo.com, port 587
# - Custom SMTP: Update MAIL_SERVER and MAIL_PORT accordingly

# Football API Configuration (For automatic match result updates)
# Get your free API key from: https://rapidapi.com/api-sports/api/api-football
FOOTBALL_API_KEY=your-rapidapi-key-here

# Note: Free tier allows 100 requests/day
# The app checks for updates every 15 minutes during matches